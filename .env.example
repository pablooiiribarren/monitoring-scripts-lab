# Servicios a monitorizar (separados por coma)
MONITOR_SERVICES=nginx,ssh,docker

# Umbrales básicos
MONITOR_CPU_THRESHOLD=4.0        # load average 1m (aprox, depende nº cores)
MONITOR_MEM_THRESHOLD=80.0       # %
MONITOR_DISK_THRESHOLD=90.0      # %

# Logging
MONITOR_LOG_DIR=logs
MONITOR_LOG_LEVEL=INFO

# Ruta de disco a monitorizar
MONITOR_DISK_PATH=/

# Fichero donde se guardan las alertas
# (por defecto: logs/alerts.log)
# MONITOR_ALERTS_FILE=/var/log/monitoring_alerts.log
