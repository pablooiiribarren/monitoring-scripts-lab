# Services to monitor (separated by comma)
MONITOR_SERVICES=nginx,ssh,docker

# Basic thresholds
MONITOR_CPU_THRESHOLD=4.0        # load average 1m (aprox, depends on number of cores)
MONITOR_MEM_THRESHOLD=80.0       # %
MONITOR_DISK_THRESHOLD=90.0      # %

# Logging
MONITOR_LOG_DIR=logs
MONITOR_LOG_LEVEL=INFO

# Disk path to monitor
MONITOR_DISK_PATH=/

# File where alerts are saved
# (default: logs/alerts.log)
# MONITOR_ALERTS_FILE=/var/log/monitoring_alerts.log
